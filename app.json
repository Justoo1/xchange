{
  "expo": {
    "name": "Xchange",
    "slug": "xchange",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "xchange",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0B",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Xchange uses the camera to scan a contact's QR code so you can exchange details.",
        "NFCReaderUsageDescription": "Xchange uses NFC so you can tap phones to exchange contacts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Xchange uses the camera to scan a contact's QR code so you can exchange details."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0B",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
